// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String
  surname         String?
  email           String    @unique
  password        String?
  googleId        String?
  documentType    String?
  documentNumber  String?
  ageRange        String?
  role            String    @default("user")
  status          String    @default("Activo")
  profileStatus   String    @default("Incompleto")
  termsAcceptedAt DateTime?
  termsVersion    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  historial       HistorialTramite[]
}

model Categoria {
  id       String    @id @default(cuid())
  name     String
  icon     String
  tramites Tramite[]
}

model Tramite {
  id               String            @id @default(cuid())
  title            String
  description      String
  code             String            @unique
  isOnline         Boolean           @default(false)
  published        Boolean           @default(true)
  type             String            @default("ciudadano")
  estimatedTime    String?
  estimatedCost    String?
  targetAgeRange   String? 
  categoriaId      String?
  categoria        Categoria?        @relation(fields: [categoriaId], references: [id])
  pasos            Paso[]
  requisitos       Requisito[]
  puntosAtencion   PuntoAtencion[]
  recomendaciones  Recomendacion[]
  externalLink     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  historial        HistorialTramite[]
}

model Paso {
  id          String   @id @default(cuid())
  order       Int
  title       String
  description String
  tramiteId   String
  tramite     Tramite  @relation(fields: [tramiteId], references: [id], onDelete: Cascade)
}

model Requisito {
  id        String   @id @default(cuid())
  title     String
  tramiteId String
  tramite   Tramite  @relation(fields: [tramiteId], references: [id], onDelete: Cascade)
}

model PuntoAtencion {
  id        String   @id @default(cuid())
  address   String
  city      String   @default("Bogotá")
  schedule  String
  phone     String
  status    String   @default("activo")
  tramiteId String
  tramite   Tramite  @relation(fields: [tramiteId], references: [id], onDelete: Cascade)
}

model Recomendacion {
  id             String  @id @default(cuid())
  text           String
  targetAgeRange String?
  tramiteId      String
  tramite        Tramite @relation(fields: [tramiteId], references: [id], onDelete: Cascade)
}

model HistorialTramite {
  id          String   @id @default(cuid())
  tramiteId   String
  userId      String
  action      String   // e.g., "ACTUALIZACION", "DESPUBLICACION", "PUBLICACION"
  changes     String?  // Could be a JSON string describing what changed
  createdAt   DateTime @default(now())
  
  tramite     Tramite  @relation(fields: [tramiteId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
